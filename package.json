{
  "name": "60s-api",
  "type": "module",
  "version": "2.53.1",
  "updateTime": "2026/06/25 12:30:36",
  "packageManager": "pnpm@10.29.2",
  "prettier": {
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "dependencies": {
    "@oak/oak": "npm:@jsr/oak__oak@^17.2.0",
    "cheerio": "^1.2.0",
    "chinese-days": "^1.5.9",
    "dayjs": "^1.11.21",
    "filesize": "^11.0.17",
    "fontkit": "^2.0.4",
    "tyme4ts": "^1.5.2",
    "whois-raw": "^0.1.10",
    "yaqrcode": "^0.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/fontkit": "^2.0.9",
    "@types/node": "^22.20.0",
    "bumpp": "^11.1.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.104.0"
  },
  "scripts": {
    "dev:no-watch": "DEV=1 PORT=4398 node --disable-warning=ExperimentalWarning node.ts",
    "dev": "DEV=1 PORT=4398 node --disable-warning=ExperimentalWarning --watch node.ts",
    "start": "PORT=4398 node --disable-warning=ExperimentalWarning node.ts",
    "prerelease": "node ./scripts/write-update-time.ts && git add . && git commit -m \"chore: update time in package.json\"",
    "release": "bumpp",
    "update-lockfile": "pnpm install && bun install && deno install --allow-scripts",
    "docker:build": "docker build -t vikiboss/60s .",
    "docker:run": "docker run --name 60s -p 4399:4399 -d vikiboss/60s",
    "docker:re-run": "docker stop 60s && docker rm 60s && pnpm run docker:run"
  }
}